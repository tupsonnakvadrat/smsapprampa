<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F1117"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📱 SMS Link Opener"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Primi SMS → otvori URL automatski"
            android:textSize="13sp"
            android:textColor="#888888"
            android:layout_marginBottom="24dp" />

        <!-- Enable/Disable switch -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#1C1F2E"
            android:padding="16dp"
            android:layout_marginBottom="16dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Aktiviraj slušanje SMS-a"
                android:textColor="#FFFFFF"
                android:textSize="15sp" />

            <Switch
                android:id="@+id/swEnabled"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                android:thumbTint="#6C63FF"
                android:trackTint="#3A3557" />
        </LinearLayout>

        <!-- Keyword -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="KLJUČNA RIJEČ (u SMS poruci)"
            android:textColor="#6C63FF"
            android:textSize="11sp"
            android:letterSpacing="0.1"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/etKeyword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#1C1F2E"
            android:textColor="#FFFFFF"
            android:textColorHint="#555555"
            android:hint="npr. OTVORI (prazno = svaka poruka)"
            android:padding="14dp"
            android:layout_marginBottom="16dp"
            android:inputType="text" />

        <!-- URL -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="CILJNI URL"
            android:textColor="#6C63FF"
            android:textSize="11sp"
            android:letterSpacing="0.1"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/etUrl"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#1C1F2E"
            android:textColor="#FFFFFF"
            android:textColorHint="#555555"
            android:hint="http://192.168.1.1/action"
            android:padding="14dp"
            android:layout_marginBottom="16dp"
            android:inputType="textUri" />

        <!-- Sender filter -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="FILTER POŠILJATELJA (opcionalno)"
            android:textColor="#6C63FF"
            android:textSize="11sp"
            android:letterSpacing="0.1"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/etSender"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#1C1F2E"
            android:textColor="#FFFFFF"
            android:textColorHint="#555555"
            android:hint="npr. +385 ili 'Banka' (prazno = svi)"
            android:padding="14dp"
            android:layout_marginBottom="24dp"
            android:inputType="phone" />

        <!-- Buttons -->
        <Button
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="💾  SPREMI POSTAVKE"
            android:backgroundTint="#6C63FF"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btnTest"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="🔗  TESTIRAJ URL"
            android:backgroundTint="#1C1F2E"
            android:textColor="#6C63FF"
            android:textSize="14sp"
            android:layout_marginBottom="24dp" />

        <!-- Status box -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="STATUS"
            android:textColor="#6C63FF"
            android:textSize="11sp"
            android:letterSpacing="0.1"
            android:layout_marginBottom="6dp" />

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#1C1F2E"
            android:textColor="#CCCCCC"
            android:textSize="13sp"
            android:padding="14dp"
            android:lineSpacingExtra="4dp"
            android:layout_marginBottom="16dp"
            android:text="Učitavanje..." />

        <!-- Last trigger info -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ZADNJI OKIDAČ"
            android:textColor="#6C63FF"
            android:textSize="11sp"
            android:letterSpacing="0.1"
            android:layout_marginBottom="6dp" />

        <TextView
            android:id="@+id/tvLastSms"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#1C1F2E"
            android:textColor="#888888"
            android:textSize="12sp"
            android:padding="14dp"
            android:lineSpacingExtra="4dp"
            android:layout_marginBottom="32dp"
            android:text="Nema primljenih SMS poruka još." />

    </LinearLayout>
</ScrollView>
